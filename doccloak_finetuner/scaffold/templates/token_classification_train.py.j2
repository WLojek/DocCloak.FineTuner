"""
Token classification fine-tuning script for DocCloak PII detection.
Hyperparameters are set by the orchestrator before each run.
"""

import json
import os
import time
from pathlib import Path

import torch
import numpy as np
from transformers import (
    AutoTokenizer,
    AutoModelForTokenClassification,
    TrainingArguments,
    Trainer,
    DataCollatorForTokenClassification,
)

from prepare import load_data, evaluate_predictions

# MPS memory optimization
os.environ.setdefault("PYTORCH_MPS_HIGH_WATERMARK_RATIO", "0.0")

# ══════════════════════════════════════════════════════════════════════════
# CONFIGURATION & HYPERPARAMETERS (set by orchestrator before each run)
# ══════════════════════════════════════════════════════════════════════════

BASE_MODEL = "{{ config.candidate_models[0] }}"
TIME_BUDGET_S = {{ config.time_budget_seconds }}

LEARNING_RATE = 2e-5
BATCH_SIZE = 16
NUM_EPOCHS = 5
WARMUP_RATIO = 0.1
WEIGHT_DECAY = 0.01
MAX_SEQ_LENGTH = 256
FREEZE_LAYERS = 0
GRADIENT_ACCUMULATION_STEPS = 1
LR_SCHEDULER = "linear"

# ══════════════════════════════════════════════════════════════════════════

start_time = time.time()


def remaining_time():
    return TIME_BUDGET_S - (time.time() - start_time)


def detect_device():
    if torch.cuda.is_available():
        return "cuda"
    if torch.backends.mps.is_available():
        return "mps"
    return "cpu"


DEVICE = detect_device()


def freeze_layers(model, n_layers: int) -> tuple[int, int]:
    """Freeze embeddings and first n_layers transformer layers.

    Works across BERT-family architectures by trying known naming patterns.
    Returns (frozen_count, total_count).
    """
    if n_layers <= 0:
        total = sum(1 for _ in model.parameters())
        return 0, total

    frozen = 0
    total = 0
    for name, param in model.named_parameters():
        total += 1
        should_freeze = False

        # Freeze embeddings
        if "embeddings" in name:
            should_freeze = True

        # Try all known BERT-family layer naming patterns
        for i in range(n_layers):
            patterns = [
                f"encoder.layer.{i}.",       # BERT, RoBERTa, XLM-R, ELECTRA
                f"transformer.layer.{i}.",   # DistilBERT
                f"bert.encoder.layer.{i}.",  # mBERT qualified path
            ]
            if any(p in name for p in patterns):
                should_freeze = True
                break

        if should_freeze:
            param.requires_grad = False
            frozen += 1

    if frozen == 0 and n_layers > 0:
        print(f"WARNING: FREEZE_LAYERS={n_layers} but no layers matched for {BASE_MODEL}.")
    else:
        print(f"Frozen {frozen}/{total} parameter groups")

    return frozen, total


def benchmark_inference(model, tokenizer, eval_ds, text_col: str, n_samples: int = 50) -> float:
    """Measure mean inference time per sample in milliseconds."""
    model.eval()
    sample_count = min(n_samples + 5, len(eval_ds))
    samples = eval_ds.select(range(sample_count))

    times = []
    with torch.no_grad():
        for i, example in enumerate(samples):
            tokens = tokenizer(
                example[text_col],
                return_tensors="pt",
                truncation=True,
                max_length=MAX_SEQ_LENGTH,
                is_split_into_words=True,
            ).to(DEVICE)

            start = time.perf_counter()
            model(**tokens)
            end = time.perf_counter()

            if i >= 5:  # skip warmup
                times.append((end - start) * 1000)

    return float(np.mean(times)) if times else 0.0


def count_params_millions(model) -> float:
    return sum(p.numel() for p in model.parameters()) / 1e6


def measure_model_size_mb(model) -> float:
    """Estimated model size in MB (fp32)."""
    total_params = sum(p.numel() for p in model.parameters())
    return (total_params * 4) / (1024 ** 2)


def tokenize_and_align(examples, tokenizer, text_col, label_col):
    """Tokenize inputs and align labels with subword tokens."""
    tokenized = tokenizer(
        examples[text_col],
        truncation=True,
        max_length=MAX_SEQ_LENGTH,
        is_split_into_words=True,
        padding=False,
    )

    all_labels = []
    for i, labels in enumerate(examples[label_col]):
        word_ids = tokenized.word_ids(batch_index=i)
        previous_word_idx = None
        label_ids = []
        for word_idx in word_ids:
            if word_idx is None:
                label_ids.append(-100)
            elif word_idx != previous_word_idx:
                label_ids.append(labels[word_idx] if word_idx < len(labels) else 0)
            else:
                label_ids.append(-100)
            previous_word_idx = word_idx
        all_labels.append(label_ids)

    tokenized["labels"] = all_labels
    return tokenized


def main():
    print(f"Time budget: {TIME_BUDGET_S}s")
    print(f"Device: {DEVICE}")
    print(f"Model: {BASE_MODEL}")
    print(f"LR: {LEARNING_RATE}, Batch: {BATCH_SIZE}, Epochs: {NUM_EPOCHS}")
    print(f"Seq length: {MAX_SEQ_LENGTH}, Freeze: {FREEZE_LAYERS}")
    print(f"Grad accum: {GRADIENT_ACCUMULATION_STEPS} (effective batch: {BATCH_SIZE * GRADIENT_ACCUMULATION_STEPS})")

    # Load data
    train_ds, eval_ds, label_list, text_col, label_col = load_data()
    id2label = {i: l for i, l in enumerate(label_list)}
    label2id = {l: i for i, l in enumerate(label_list)}

    # Load tokenizer and model
    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL)
    model = AutoModelForTokenClassification.from_pretrained(
        BASE_MODEL,
        num_labels=len(label_list),
        id2label=id2label,
        label2id=label2id,
        ignore_mismatched_sizes=True,
    )

    # Model metrics
    params_m = count_params_millions(model)
    size_mb = measure_model_size_mb(model)
    print(f"Parameters: {params_m:.1f}M ({size_mb:.0f}MB)")

    # Freeze layers
    if FREEZE_LAYERS > 0:
        freeze_layers(model, FREEZE_LAYERS)

    # Tokenize datasets
    tokenized_train = train_ds.map(
        lambda x: tokenize_and_align(x, tokenizer, text_col, label_col),
        batched=True,
        remove_columns=train_ds.column_names,
    )
    tokenized_eval = eval_ds.map(
        lambda x: tokenize_and_align(x, tokenizer, text_col, label_col),
        batched=True,
        remove_columns=eval_ds.column_names,
    )

    data_collator = DataCollatorForTokenClassification(tokenizer=tokenizer)

    # Training arguments
    training_args = TrainingArguments(
        output_dir="./checkpoints",
        learning_rate=LEARNING_RATE,
        per_device_train_batch_size=BATCH_SIZE,
        per_device_eval_batch_size=BATCH_SIZE * 2,
        num_train_epochs=NUM_EPOCHS,
        warmup_steps=int(WARMUP_RATIO * (len(tokenized_train) // (BATCH_SIZE * GRADIENT_ACCUMULATION_STEPS)) * NUM_EPOCHS),
        weight_decay=WEIGHT_DECAY,
        gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,
        lr_scheduler_type=LR_SCHEDULER,
        eval_strategy="epoch",
        save_strategy="epoch",
        load_best_model_at_end=True,
        metric_for_best_model="f1",
        greater_is_better=True,
        save_total_limit=2,
        logging_steps=50,
        report_to="none",
        fp16=(DEVICE == "cuda"),
    )

    def compute_metrics(eval_preds):
        logits, labels = eval_preds
        predictions = np.argmax(logits, axis=-1)
        return evaluate_predictions(predictions, labels, label_list)

    trainer = Trainer(
        model=model,
        args=training_args,
        train_dataset=tokenized_train,
        eval_dataset=tokenized_eval,
        processing_class=tokenizer,
        data_collator=data_collator,
        compute_metrics=compute_metrics,
    )

    # Train
    print(f"\nStarting training... ({remaining_time():.0f}s remaining)")
    trainer.train()

    # Final evaluation
    print(f"\nRunning final evaluation... ({remaining_time():.0f}s remaining)")
    eval_results = trainer.evaluate()

    # Save best model
    best_model_dir = Path("./best_model")
    trainer.save_model(str(best_model_dir))
    tokenizer.save_pretrained(str(best_model_dir))
    print(f"Best model saved to {best_model_dir}")

    # Benchmark inference speed
    print("Benchmarking inference speed...")
    model.to(DEVICE)
    inference_ms = benchmark_inference(model, tokenizer, eval_ds, text_col)

    # Output results
    elapsed = time.time() - start_time
    result = {
        "model": BASE_MODEL,
        "f1": eval_results.get("eval_f1", 0.0),
        "precision": eval_results.get("eval_precision", 0.0),
        "recall": eval_results.get("eval_recall", 0.0),
        "loss": eval_results.get("eval_loss", 999.0),
        "params_M": round(params_m, 1),
        "size_mb": round(size_mb, 0),
        "inference_ms": round(inference_ms, 2),
        "duration_s": elapsed,
    }

    print(f"\n{'='*60}")
    print(f"RESULT SUMMARY")
    print(f"{'='*60}")
    print(f"Model:     {BASE_MODEL} ({params_m:.1f}M params, {size_mb:.0f}MB)")
    print(f"F1:        {result['f1']:.4f}")
    print(f"Precision: {result['precision']:.4f}")
    print(f"Recall:    {result['recall']:.4f}")
    print(f"Loss:      {result['loss']:.4f}")
    print(f"Inference: {inference_ms:.1f}ms/sample")
    print(f"Duration:  {elapsed:.0f}s ({elapsed/60:.1f}m)")
    print(f"{'='*60}")

    Path("last_result.json").write_text(json.dumps(result, indent=2))

    return result


if __name__ == "__main__":
    main()
